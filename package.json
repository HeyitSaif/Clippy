{
  "name": "clippy",
  "version": "2.0.1",
  "description": "A modern cross-platform clipboard manager for macOS, Windows, and Linux",
  "main": "./out/main/index.js",
  "author": "Saif",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "npm run rebuild:native && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild:native": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:dir": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir",
    "dist:dir:win": "npm run build && electron-builder --win --dir",
    "dist:dir:linux": "npm run build && electron-builder --linux --dir",
    "dist:publish": "npm run build && electron-builder --mac --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-log": "^5.4.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-virtual": "^3.14.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "electron": "^41.10.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^6.0.0-beta.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^3.2.7"
  },
  "build": {
    "appId": "com.clippy.app",
    "productName": "Clippy",
    "directories": {
      "output": "release"
    },
    "electronLanguages": [
      "en"
    ],
    "files": [
      "out/**/*",
      "resources/**/*",
      "!**/node_modules/better-sqlite3/deps{,/**/*}",
      "!**/node_modules/better-sqlite3/src{,/**/*}",
      "!**/node_modules/better-sqlite3/build/Release/obj{,/**/*}",
      "!**/node_modules/better-sqlite3/build/Release/obj.target{,/**/*}",
      "!**/node_modules/better-sqlite3/build/Release/.deps{,/**/*}",
      "!**/node_modules/*/{README,CHANGELOG,readme,changelog}*",
      "!**/node_modules/*/*.md",
      "!**/node_modules/*/*.map",
      "!**/node_modules/*/test{,/**/*}",
      "!**/node_modules/*/tests{,/**/*}"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/build/Release/*.node"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSUserNotificationAlertStyle": "alert"
      }
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Saif"
    },
    "publish": {
      "provider": "github",
      "owner": "HeyitSaif",
      "repo": "Clippy"
    }
  }
}
